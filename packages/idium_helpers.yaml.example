automation:
  - id: office_scene_custom_on_manual_change
    alias: Office - Mark scene as Custom on manual light change
    mode: restart
    trigger:
      - platform: state
        entity_id:
          - light.office_hue_filament_bulb_1
          - light.office_hue_filament_bulb_2
          - light.office_hue_filament_bulb_3
          - light.office_panel_light_controller
        attribute:
          - brightness
          - color_temp
          - color_temp_kelvin
          - rgb_color
          - hs_color
          - xy_color
    condition:
      - condition: state
        entity_id: input_boolean.office_scene_applying
        state: "off"
      - condition: template
        value_template: "{{ states('input_select.office_active_scene') not in ['None', 'Custom'] }}"
    action:
      - delay: "00:00:02"
      - condition: state
        entity_id: input_boolean.office_scene_applying
        state: "off"
      - action: input_select.select_option
        target:
          entity_id: input_select.office_active_scene
        data:
          option: Custom

